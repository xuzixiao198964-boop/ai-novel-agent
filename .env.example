# AI Novel Media Agent 环境变量配置

# 服务器配置
HOST=0.0.0.0
PORT=9000
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/ai_novel_agent
REDIS_URL=redis://localhost:6379/0

# 文件存储
DATA_DIR=/opt/ai-novel-agent/data
MEMORY_DIR=/opt/ai-novel-agent/memory
UPLOAD_DIR=/opt/ai-novel-agent/uploads

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 视频生成配置
FFMPEG_PATH=/usr/bin/ffmpeg
TTS_PROVIDER=openai  # openai, edge, elevenlabs
VIDEO_MODEL=veo  # veo, sora, kling

# 支付配置
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id

# 第三方平台配置
DOUYIN_APP_KEY=your-douyin-app-key
DOUYIN_APP_SECRET=your-douyin-app-secret
XIAOHONGSHU_APP_KEY=your-xiaohongshu-app-key
XIAOHONGSHU_APP_SECRET=your-xiaohongshu-app-secret

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/ai-novel-agent/app.log

# 性能配置
MAX_CONCURRENT_TASKS=3
TASK_TIMEOUT_SECONDS=86400  # 24小时
QUEUE_MAX_SIZE=100

# 测试配置
TEST_MODE=false
MOCK_LLM=false
TEST_CHAPTERS=6