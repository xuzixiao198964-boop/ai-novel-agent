# 主站监听端口（默认 9000，与 uvicorn 一致）
# PORT=9000

# DeepSeek API（与 OpenAI 兼容）
# 可写 https://api.deepseek.com 或 https://api.deepseek.com/v1（代码会自动补 /v1/chat/completions）
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
# MOCK_LLM=0（默认不写即走真实 API；=1 仅用于无密钥时的流程验证）

# OpenClaw 示例（通常无需 API Key）
# LLM_PROVIDER=openclaw
# LLM_API_BASE=http://127.0.0.1:8001
# LLM_API_KEY=
# LLM_MODEL=openclaw-chat

# 可选：限速（秒）
# AGENT_INTERVAL_SECONDS=1.0
# STEP_INTERVAL_SECONDS=0.2

# 测试短篇：设 TOTAL_CHAPTERS=5、WORDS_PER_CHAPTER=1500 可快速跑通一部
# 正式：不设或 0，章节数由大纲决定（约 200–500 章），每章不少于 10000 字
# TOTAL_CHAPTERS=5
# WORDS_PER_CHAPTER=1500
# 只写前 N 章（0=写满）：MAX_CHAPTERS_TO_WRITE=20
# 目录章数范围：CHAPTER_RANGE_MIN=200 CHAPTER_RANGE_MAX=201
